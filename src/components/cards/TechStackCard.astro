---
import BentoCard from "../BentoCard.astro"

const techItems = [
  { name: "Rust" },
  { name: "Go" },
  { name: "Haskell" },
  { name: "Nix" },
  { name: "Docker" },
  { name: "C++" },
]
---

<BentoCard index={1} className="col-span-1">
  <p class="mb-4 text-xs font-medium uppercase tracking-wider text-muted-foreground">
    Tech Stack
  </p>
  <div class="grid grid-cols-3 gap-3">
    {techItems.map((item) => (
      <div
        class="group flex flex-col items-center gap-1.5 rounded-xl p-2 transition-colors hover:bg-white/5"
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-muted-foreground transition-all group-hover:bg-emerald-500/10 group-hover:text-emerald-400 group-hover:shadow-[0_0_12px_rgba(16,185,129,0.15)]">
          {item.name === "Rust" && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="9" />
              <path d="M12 7v2m0 6v2M7 12h2m6 0h2M8.5 8.5l1.4 1.4m4.2 4.2l1.4 1.4M15.5 8.5l-1.4 1.4m-4.2 4.2l-1.4 1.4" />
              <circle cx="12" cy="12" r="3" />
            </svg>
          )}
          {item.name === "Go" && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M13 6l-1-3-1 3M7 12h3l-1 6h6l-1-6h3" />
              <path d="M8 9h8" />
              <circle cx="9.5" cy="7" r="0.5" fill="currentColor" />
              <circle cx="14.5" cy="7" r="0.5" fill="currentColor" />
              <path d="M6 15c-1 2 1 5 6 5s7-3 6-5" />
            </svg>
          )}
          {item.name === "Haskell" && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
              <path d="M1 4l5 8-5 8h3.5l5-8-5-8H1zm5.5 0l5 8-5 8H10l3-4.5L16 20h3.5l-5-8 2.5-4h-3.5l-1.5 2.25L10 4H6.5z" />
            </svg>
          )}
          {item.name === "Nix" && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2v4m0 12v4M2 12h4m12 0h4M5.64 5.64l2.83 2.83m7.07 7.07l2.83 2.83M18.36 5.64l-2.83 2.83m-7.07 7.07l-2.83 2.83" />
            </svg>
          )}
          {item.name === "Docker" && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
              <path d="M13.983 11.078h2.119a.186.186 0 0 0 .186-.185V9.006a.186.186 0 0 0-.186-.186h-2.119a.185.185 0 0 0-.185.185v1.888c0 .102.083.185.185.185m-2.954-5.43h2.118a.186.186 0 0 0 .186-.186V3.574a.186.186 0 0 0-.186-.185h-2.118a.185.185 0 0 0-.185.185v1.888c0 .102.082.185.185.186m0 2.716h2.118a.187.187 0 0 0 .186-.186V6.29a.186.186 0 0 0-.186-.185h-2.118a.185.185 0 0 0-.185.185v1.887c0 .102.082.185.185.186m-2.93 0h2.12a.186.186 0 0 0 .184-.186V6.29a.185.185 0 0 0-.185-.185H8.1a.185.185 0 0 0-.185.185v1.887c0 .102.083.185.185.186m-2.964 0h2.119a.186.186 0 0 0 .185-.186V6.29a.185.185 0 0 0-.185-.185H5.136a.186.186 0 0 0-.186.185v1.887c0 .102.084.185.186.186m5.893 2.715h2.118a.186.186 0 0 0 .186-.185V9.006a.186.186 0 0 0-.186-.186h-2.118a.185.185 0 0 0-.185.185v1.888c0 .102.082.185.185.185m-2.93 0h2.12a.185.185 0 0 0 .184-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.185.185 0 0 0-.184.185v1.888c0 .102.083.185.185.185m-2.964 0h2.119a.185.185 0 0 0 .185-.185V9.006a.185.185 0 0 0-.185-.186H5.136a.186.186 0 0 0-.186.185v1.888c0 .102.084.185.186.185m-2.92 0h2.12a.185.185 0 0 0 .184-.185V9.006a.185.185 0 0 0-.184-.186h-2.12a.185.185 0 0 0-.184.185v1.888c0 .102.082.185.185.185M23.763 9.89c-.065-.051-.672-.51-1.954-.51-.338.001-.676.03-1.01.087-.248-1.7-1.653-2.53-1.716-2.566l-.344-.199-.226.327c-.284.438-.49.922-.612 1.43-.23.97-.09 1.882.403 2.661-.595.332-1.55.413-1.744.42H.751a.751.751 0 0 0-.75.748 11.376 11.376 0 0 0 .692 4.062c.545 1.428 1.355 2.48 2.41 3.124 1.18.723 3.1 1.137 5.275 1.137.983.003 1.963-.086 2.93-.266a12.248 12.248 0 0 0 3.823-1.389c.98-.567 1.86-1.288 2.61-2.136 1.252-1.418 1.998-2.997 2.553-4.4h.221c1.372 0 2.215-.549 2.68-1.009.309-.293.55-.65.707-1.046l.098-.288-.313-.212z" />
            </svg>
          )}
          {item.name === "C++" && (
            <svg viewBox="0 0 24 24" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 3l-4 9 4 9h7l4-9-4-9H6z" />
              <path d="M16 9h4m-2-2v4" />
              <path d="M20 9h4m-2-2v4" />
            </svg>
          )}
        </div>
        <span class="text-[10px] font-medium text-muted-foreground transition-colors group-hover:text-foreground">
          {item.name}
        </span>
      </div>
    ))}
  </div>
</BentoCard>
