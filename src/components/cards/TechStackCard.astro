---

<BentoCard index={1} className="col-span-1">
  <p class="mb-4 text-xs font-medium uppercase tracking-wider text-muted-foreground">
    Tech Stack
  </p>
  <div class="grid grid-cols-3 gap-3">
    {techItems.map((item) => (
      <div
        class="group flex flex-col items-center gap-1.5 rounded-xl p-2 transition-colors hover:bg-white/5"
      >
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-white/5 text-muted-foreground transition-all group-hover:bg-emerald-500/10 group-hover:text-emerald-400 group-hover:shadow-[0_0_12px_rgba(16,185,129,0.15)]">
          <svg viewBox="0 0 24 24" class="h-5 w-5" fill="currentColor">
            <path d={iconPaths[item.icon]} />
          </svg>
        </div>
        <span class="text-[10px] font-medium text-muted-foreground transition-colors group-hover:text-foreground">
          {item.name}
        </span>
      </div>
    ))}
  </div>
</BentoCard>
